        "respondWith": "text",
        "responseBody": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>RecebAI</title>\n<link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap\" rel=\"stylesheet\">\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { font-family: 'DM Sans', sans-serif; background: #f4f6fb; display: flex; min-height: 100vh; }\n.sidebar { width: 220px; background: #1a1a2e; color: #fff; padding: 0; display: flex; flex-direction: column; flex-shrink: 0; }\n.sidebar-logo { padding: 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.08); }\n.sidebar-logo h1 { font-size: 20px; font-weight: 600; color: #fff; }\n.sidebar-logo span { color: #4f8ef7; }\n.sidebar-logo p { font-size: 12px; color: rgba(255,255,255,0.4); margin-top: 2px; }\n.nav { padding: 12px 0; flex: 1; }\n.nav-item { display: flex; align-items: center; gap: 10px; padding: 11px 20px; cursor: pointer; font-size: 14px; color: rgba(255,255,255,0.55); transition: all 0.15s; border-left: 3px solid transparent; }\n.nav-item:hover { background: rgba(255,255,255,0.05); color: #fff; }\n.nav-item.active { background: rgba(79,142,247,0.12); color: #4f8ef7; border-left-color: #4f8ef7; }\n.nav-item svg { width: 18px; height: 18px; flex-shrink: 0; }\n.main { flex: 1; padding: 32px; overflow-y: auto; }\n.page { display: none; }\n.page.active { display: block; }\n.page-title { font-size: 22px; font-weight: 600; color: #1a1a2e; margin-bottom: 6px; }\n.page-sub { font-size: 14px; color: #8a94a6; margin-bottom: 28px; }\n.stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 32px; }\n.stat-card { background: #fff; border-radius: 12px; padding: 20px; border: 1px solid #e8ecf4; }\n.stat-label { font-size: 13px; color: #8a94a6; margin-bottom: 8px; }\n.stat-value { font-size: 28px; font-weight: 600; color: #1a1a2e; }\n.stat-value.blue { color: #4f8ef7; }\n.stat-value.amber { color: #f59e0b; }\n.stat-value.green { color: #10b981; }\n.card { background: #fff; border-radius: 12px; border: 1px solid #e8ecf4; padding: 24px; }\n.form-group { margin-bottom: 18px; }\n.form-label { display: block; font-size: 13px; font-weight: 500; color: #4a5568; margin-bottom: 6px; }\n.form-input { width: 100%; padding: 10px 14px; border: 1px solid #dde3ee; border-radius: 8px; font-size: 14px; font-family: 'DM Sans', sans-serif; outline: none; transition: border 0.15s; color: #1a1a2e; background: #fff; }\n.form-input:focus { border-color: #4f8ef7; box-shadow: 0 0 0 3px rgba(79,142,247,0.1); }\n.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }\n.btn { padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 500; cursor: pointer; border: none; font-family: 'DM Sans', sans-serif; transition: all 0.15s; }\n.btn-primary { background: #4f8ef7; color: #fff; }\n.btn-primary:hover { background: #3a7ce8; }\n.btn-primary:disabled { background: #a0b8f0; cursor: not-allowed; }\n.btn-sm { padding: 6px 14px; font-size: 13px; }\n.btn-confirm { background: #10b981; color: #fff; }\n.btn-confirm:hover { background: #059669; }\n.alert { padding: 12px 16px; border-radius: 8px; font-size: 14px; margin-bottom: 20px; display: none; }\n.alert-success { background: #d1fae5; color: #065f46; }\n.alert-error { background: #fee2e2; color: #991b1b; }\n.search-bar { margin-bottom: 20px; }\n.table-wrap { overflow-x: auto; }\ntable { width: 100%; border-collapse: collapse; font-size: 14px; }\nth { text-align: left; padding: 10px 14px; font-size: 12px; font-weight: 500; color: #8a94a6; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #e8ecf4; }\ntd { padding: 13px 14px; border-bottom: 1px solid #f0f3f9; color: #2d3748; vertical-align: middle; }\ntr:last-child td { border-bottom: none; }\ntr:hover td { background: #f8faff; }\n.badge { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 500; }\n.badge-waiting { background: #fef3c7; color: #92400e; }\n.badge-done { background: #d1fae5; color: #065f46; }\n.empty-state { text-align: center; padding: 48px 20px; color: #8a94a6; }\n.modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: none; align-items: center; justify-content: center; z-index: 100; }\n.modal-overlay.open { display: flex; }\n.modal { background: #fff; border-radius: 14px; padding: 28px; width: 400px; max-width: 90vw; }\n.modal h3 { font-size: 17px; font-weight: 600; color: #1a1a2e; margin-bottom: 6px; }\n.modal p { font-size: 14px; color: #8a94a6; margin-bottom: 20px; }\n.modal-actions { display: flex; gap: 10px; justify-content: flex-end; }\n.btn-cancel { background: #f4f6fb; color: #4a5568; }\n.loading { text-align: center; padding: 40px; color: #8a94a6; font-size: 14px; }\n</style>\n</head>\n<body>\n\n<div class=\"sidebar\">\n  <div class=\"sidebar-logo\">\n    <h1>Receb<span>AI</span></h1>\n    <p>Gestão de Encomendas</p>\n  </div>\n  <nav class=\"nav\">\n    <div class=\"nav-item active\" onclick=\"navigate('dashboard')\">\n      <svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\"/></svg>\n      Dashboard\n    </div>\n    <div class=\"nav-item\" onclick=\"navigate('portaria')\">\n      <svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path d=\"M12 2l7 4v6c0 5-7 10-7 10S5 17 5 12V6l7-4z\"/></svg>\n      Portaria\n    </div>\n    <div class=\"nav-item\" onclick=\"navigate('encomendas')\">\n      <svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path d=\"M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z\"/><path d=\"M16 3H8l-2 4h12l-2-4z\"/></svg>\n      Encomendas\n    </div>\n    <div class=\"nav-item\" onclick=\"navigate('historico')\">\n      <svg fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M12 6v6l4 2\"/></svg>\n      Histórico\n    </div>\n  </nav>\n</div>\n\n<main class=\"main\">\n\n  <div id=\"dashboard\" class=\"page active\">\n    <div class=\"page-title\">Dashboard</div>\n    <div class=\"page-sub\">Resumo geral das encomendas</div>\n    <div class=\"stats-grid\">\n      <div class=\"stat-card\"><div class=\"stat-label\">Total de Encomendas</div><div class=\"stat-value blue\" id=\"stat-total\">—</div></div>\n      <div class=\"stat-card\"><div class=\"stat-label\">Aguardando Retirada</div><div class=\"stat-value amber\" id=\"stat-aguardando\">—</div></div>\n      <div class=\"stat-card\"><div class=\"stat-label\">Retiradas Hoje</div><div class=\"stat-value green\" id=\"stat-hoje\">—</div></div>\n    </div>\n    <div class=\"card\">\n      <div style=\"font-size:15px;font-weight:500;color:#1a1a2e;margin-bottom:16px\">Encomendas aguardando retirada</div>\n      <div id=\"dashboard-pending\"><div class=\"loading\">Carregando...</div></div>\n    </div>\n  </div>\n\n  <div id=\"portaria\" class=\"page\">\n    <div class=\"page-title\">Registrar Encomenda</div>\n    <div class=\"page-sub\">Preencha os dados da encomenda que chegou na portaria</div>\n    <div class=\"card\" style=\"max-width:580px\">\n      <div id=\"form-alert\" class=\"alert\"></div>\n      <div class=\"form-row\">\n        <div class=\"form-group\">\n          <label class=\"form-label\">Código de Rastreio</label>\n          <input class=\"form-input\" id=\"f-tracking\" placeholder=\"BR123456789BR\" />\n        </div>\n        <div class=\"form-group\">\n          <label class=\"form-label\">Transportadora</label>\n          <input class=\"form-input\" id=\"f-transportadora\" placeholder=\"Correios, Jadlog...\" />\n        </div>\n      </div>\n      <div class=\"form-row\">\n        <div class=\"form-group\">\n          <label class=\"form-label\">Nome do Destinatário</label>\n          <input class=\"form-input\" id=\"f-nome\" placeholder=\"João Silva\" />\n        </div>\n        <div class=\"form-group\">\n          <label class=\"form-label\">Unidade / Apto</label>\n          <input class=\"form-input\" id=\"f-unidade\" placeholder=\"Apto 42 - Bloco B\" />\n        </div>\n      </div>\n      <button class=\"btn btn-primary\" id=\"btn-registrar\" onclick=\"registrarEncomenda()\">Registrar Encomenda</button>\n    </div>\n  </div>\n\n  <div id=\"encomendas\" class=\"page\">\n    <div class=\"page-title\">Encomendas</div>\n    <div class=\"page-sub\">Todas as encomendas registradas</div>\n    <div class=\"search-bar\">\n      <input class=\"form-input\" id=\"search-input\" placeholder=\"Buscar por nome ou unidade...\" oninput=\"filterTable()\" style=\"max-width:340px\" />\n    </div>\n    <div class=\"card\">\n      <div id=\"encomendas-table\"><div class=\"loading\">Carregando...</div></div>\n    </div>\n  </div>\n\n  <div id=\"historico\" class=\"page\">\n    <div class=\"page-title\">Histórico</div>\n    <div class=\"page-sub\">Encomendas já retiradas</div>\n    <div class=\"card\">\n      <div id=\"historico-table\"><div class=\"loading\">Carregando...</div></div>\n    </div>\n  </div>\n\n</main>\n\n<div class=\"modal-overlay\" id=\"modal-overlay\">\n  <div class=\"modal\">\n    <h3>Confirmar Retirada</h3>\n    <p>Informe quem está retirando a encomenda</p>\n    <div class=\"form-group\">\n      <label class=\"form-label\">Nome de quem está retirando</label>\n      <input class=\"form-input\" id=\"modal-retirada-por\" placeholder=\"Nome completo\" />\n    </div>\n    <div class=\"modal-actions\">\n      <button class=\"btn btn-cancel\" onclick=\"closeModal()\">Cancelar</button>\n      <button class=\"btn btn-confirm\" onclick=\"confirmarRetirada()\">Confirmar</button>\n    </div>\n  </div>\n</div>\n\n<script>\nconst API_BASE = 'https://bripper.app.n8n.cloud/webhook';\nlet allEncomendas = [];\nlet currentRetiradaId = null;\n\nfunction navigate(page) {\n  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));\n  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));\n  document.getElementById(page).classList.add('active');\n  const idx = ['dashboard','portaria','encomendas','historico'].indexOf(page);\n  document.querySelectorAll('.nav-item')[idx].classList.add('active');\n  if (page === 'dashboard') loadDashboard();\n  if (page === 'encomendas') loadEncomendas();\n  if (page === 'historico') loadHistorico();\n}\n\nasync function loadDashboard() {\n  try {\n    const [stats, enc] = await Promise.all([\n      fetch(API_BASE + '/recebai/stats').then(r => r.json()),\n      fetch(API_BASE + '/recebai/encomendas?status=aguardando_retirada').then(r => r.json())\n    ]);\n    document.getElementById('stat-total').textContent = stats.total ?? 0;\n    document.getElementById('stat-aguardando').textContent = stats.aguardando ?? 0;\n    document.getElementById('stat-hoje').textContent = stats.retirado_hoje ?? 0;\n    const pending = Array.isArray(enc) ? enc : [];\n    const el = document.getElementById('dashboard-pending');\n    if (pending.length === 0) { el.innerHTML = '<div class=\"empty-state\">Nenhuma encomenda aguardando retirada</div>'; return; }\n    el.innerHTML = renderTable(pending, false);\n  } catch(e) { console.error(e); }\n}\n\nasync function loadEncomendas() {\n  try {\n    const data = await fetch(API_BASE + '/recebai/encomendas').then(r => r.json());\n    allEncomendas = Array.isArray(data) ? data : [];\n    renderEncomendasTable();\n  } catch(e) { console.error(e); }\n}\n\nasync function loadHistorico() {\n  try {\n    const data = await fetch(API_BASE + '/recebai/encomendas?status=retirado').then(r => r.json());\n    const rows = Array.isArray(data) ? data : [];\n    const el = document.getElementById('historico-table');\n    if (rows.length === 0) { el.innerHTML = '<div class=\"empty-state\">Nenhuma encomenda retirada ainda</div>'; return; }\n    el.innerHTML = renderTable(rows, false);\n  } catch(e) { console.error(e); }\n}\n\nfunction filterTable() {\n  const q = document.getElementById('search-input').value.toLowerCase();\n  const filtered = allEncomendas.filter(e =>\n    (e.destinatario_nome||'').toLowerCase().includes(q) ||\n    (e.destinatario_unidade||'').toLowerCase().includes(q)\n  );\n  document.getElementById('encomendas-table').innerHTML = filtered.length ? renderTable(filtered, true) : '<div class=\"empty-state\">Nenhum resultado encontrado</div>';\n}\n\nfunction renderEncomendasTable() {\n  const el = document.getElementById('encomendas-table');\n  if (allEncomendas.length === 0) { el.innerHTML = '<div class=\"empty-state\">Nenhuma encomenda cadastrada</div>'; return; }\n  el.innerHTML = renderTable(allEncomendas, true);\n}\n\nfunction renderTable(rows, showAction) {\n  const header = `<table><thead><tr><th>Código</th><th>Destinatário</th><th>Unidade</th><th>Transportadora</th><th>Status</th><th>Chegada</th>${showAction ? '<th>Ação</th>' : ''}</tr></thead><tbody>`;\n  const body = rows.map(r => {\n    const isWaiting = r.status === 'aguardando_retirada';\n    const badge = isWaiting\n      ? '<span class=\"badge badge-waiting\">⏳ Aguardando</span>'\n      : '<span class=\"badge badge-done\">✓ Retirado</span>';\n    const action = showAction && isWaiting\n      ? `<button class=\"btn btn-sm btn-confirm\" onclick=\"openModal('${r.id}')\">Confirmar Retirada</button>`\n      : (showAction ? '<span style=\"color:#8a94a6;font-size:13px\">—</span>' : '');\n    const date = r.created_at ? new Date(r.created_at).toLocaleDateString('pt-BR') : '—';\n    return `<tr><td style=\"font-family:monospace;font-size:13px\">${r.tracking_code||'—'}</td><td>${r.destinatario_nome||'—'}</td><td>${r.destinatario_unidade||'—'}</td><td>${r.transportadora||'—'}</td><td>${badge}</td><td>${date}</td>${showAction ? `<td>${action}</td>` : ''}</tr>`;\n  }).join('');\n  return header + body + '</tbody></table>';\n}\n\nasync function registrarEncomenda() {\n  const tracking = document.getElementById('f-tracking').value.trim();\n  const nome = document.getElementById('f-nome').value.trim();\n  const unidade = document.getElementById('f-unidade').value.trim();\n  const transp = document.getElementById('f-transportadora').value.trim();\n  const alertEl = document.getElementById('form-alert');\n  if (!tracking || !nome || !unidade || !transp) {\n    showAlert(alertEl, 'error', 'Preencha todos os campos.');\n    return;\n  }\n  const btn = document.getElementById('btn-registrar');\n  btn.disabled = true; btn.textContent = 'Registrando...';\n  try {\n    const res = await fetch(API_BASE + '/recebai/encomendas', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ tracking_code: tracking, destinatario_nome: nome, destinatario_unidade: unidade, transportadora: transp })\n    });\n    if (!res.ok) throw new Error();\n    showAlert(alertEl, 'success', 'Encomenda registrada com sucesso!');\n    document.getElementById('f-tracking').value = '';\n    document.getElementById('f-nome').value = '';\n    document.getElementById('f-unidade').value = '';\n    document.getElementById('f-transportadora').value = '';\n  } catch(e) {\n    showAlert(alertEl, 'error', 'Erro ao registrar. Tente novamente.');\n  }\n  btn.disabled = false; btn.textContent = 'Registrar Encomenda';\n}\n\nfunction showAlert(el, type, msg) {\n  el.className = 'alert alert-' + type;\n  el.textContent = msg;\n  el.style.display = 'block';\n  setTimeout(() => { el.style.display = 'none'; }, 4000);\n}\n\nfunction openModal(id) {\n  currentRetiradaId = id;\n  document.getElementById('modal-retirada-por').value = '';\n  document.getElementById('modal-overlay').classList.add('open');\n}\n\nfunction closeModal() {\n  document.getElementById('modal-overlay').classList.remove('open');\n  currentRetiradaId = null;\n}\n\nasync function confirmarRetirada() {\n  const nome = document.getElementById('modal-retirada-por').value.trim();\n  if (!nome) { alert('Informe o nome de quem está retirando.'); return; }\n  try {\n    const res = await fetch(API_BASE + '/recebai/encomendas/retirar', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ id: currentRetiradaId, retirada_por: nome })\n    });\n    if (!res.ok) throw new Error();\n    closeModal();\n    loadEncomendas();\n    loadDashboard();\n  } catch(e) {\n    alert('Erro ao confirmar retirada. Tente novamente.');\n  }\n}\n\nloadDashboard();\n</script>\n</body>\n</html>",
